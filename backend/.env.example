# Application
APP_NAME="Inventory & Order Management System"
APP_VERSION="1.0.0"
DEBUG=false

# PostgreSQL — matches docker-compose.yml defaults
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/inventory_db

# Connection pool (optional — these are the defaults)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# CORS — comma-separated allowed origins; use * for development only
CORS_ORIGINS=*
