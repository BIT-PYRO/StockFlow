# Copy to .env and fill in values before running docker compose.
# All values shown are the defaults used when the variable is unset.

# ── Database ────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=inventory_db
POSTGRES_PORT=5432

# ── Backend ─────────────────────────────────────────
# Comma-separated list of allowed CORS origins.
CORS_ORIGINS=http://localhost,http://localhost:80
# Number of Uvicorn worker processes inside the backend container.
UVICORN_WORKERS=2

# ── Frontend ─────────────────────────────────────────
# Host port the nginx container listens on.
APP_PORT=80
